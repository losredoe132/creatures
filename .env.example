# World size controls the toroidal wrap bounds for the simulation.
# Use half-sizes because the world is centered at (0, 0).
WORLD_HALF_WIDTH=400
WORLD_HALF_HEIGHT=250

# Grid resolution used for overlay rendering and same-cell detection.
# Number of cells across X and Y in the world.
GRID_RESOLUTION_X=15
GRID_RESOLUTION_Y=10

# Tuning values for interactions, movement, and metabolism.
PLANT_CONSUME_PER_CELL=20.0
PLANT_GROWTH_PER_SEC=0.05
PLANT_MAX_ENERGY=120.0
PLANT_SPAWN_RATE_PER_SEC=0.1
PLANT_BASE_SIZE=4.0
PLANT_SIZE_PER_SQRT_ENERGY=1.3
ANIMAL_BASE_SIZE=6.0
ANIMAL_SIZE_PER_SQRT_ENERGY=1.4
ANIMAL_CROWDING_PENALTY=1.0
PLANT_CROWDING_PENALTY=0.5
ANIMAL_BASE_ENERGY_DRAIN_PER_SEC=0.15
ANIMAL_SPEED_ENERGY_DRAIN_PER_SEC=5
ANIMAL_SPEED_EXPONENT=0.9
ANIMAL_SPEED_REFERENCE=220.0
ANIMAL_MAX_SPEED=120.0
SPEED_SIGMOID_STEEPNESS=4.0
