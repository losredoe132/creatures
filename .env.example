# World size controls the toroidal wrap bounds for the simulation.
# Use half-sizes because the world is centered at (0, 0).
WORLD_HALF_WIDTH=600
WORLD_HALF_HEIGHT=400
ANIMAL_SPAWN_ENERGY=50.0

# Spawn Control
PLANT_SPAWN_RATE_PER_SEC=2.0
ANIMAL_SPAWN_RATE_PER_SEC=0.1

# Tuning values for interactions, movement, and metabolism.
PLANT_CONSUME_PER_COLLISION=20.0
PLANT_GROWTH_PER_SEC=10
PLANT_MAX_ENERGY=120.0

PLANT_BASE_SIZE=10.0
PLANT_SIZE_PER_SQRT_ENERGY=0.4
ANIMAL_BASE_SIZE=6.0
ANIMAL_SIZE_PER_SQRT_ENERGY=0.4
ANIMAL_BASE_ENERGY_DRAIN_PER_SEC=1.0
ANIMAL_SPEED_ENERGY_DRAIN_PER_SEC=3.0
ANIMAL_SPEED_EXPONENT=0.9
ANIMAL_SPEED_REFERENCE=120.0
ANIMAL_MAX_SPEED=140.0
SPEED_SIGMOID_STEEPNESS=2.0
VISION_RANGE=100.0
VISION_FOV_RADIANS=3.14
REPRODUCTION_ENERGY_MULTIPLIER=3.0
OFFSPRING_ENERGY_JITTER=0.1
GENOME_MUTATION_STRENGTH=0.05
REPRODUCTION_POSITION_JITTER=25.0

HERBIVORE_METABOLISM_RATIO=3.0
CARNIVORE_METABOLISM_RATIO=1.0
OMNIVORE_METABOLISM_RATIO=0.3

RANDOM_SEED=1234


